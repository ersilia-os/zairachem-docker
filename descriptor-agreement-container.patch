+class DescriptorDendrogramPlot(BasePlot):
+  """Hierarchical clustering of the descriptors by rank agreement (distance = 1 − Spearman, average
+  linkage). Descriptors that merge early make near-redundant predictions; one that joins late adds a
+  distinct signal to the pool. Classification only, fit-only. Skipped if SciPy is unavailable."""
+
+  def __init__(self, ax, path):
+    BasePlot.__init__(self, ax=ax, path=path, cells=(2, 2))
+    self.name = "descriptor-dendrogram"
+    self.is_available = False
+    if not self.has_clf_data():
+      return
+    rf = ResultsFetcher(path=path)
+    tasks = rf.get_clf_tasks()
+    if not tasks:
+      return
+    df = rf._read_individual_estimator_results(tasks[0])
+    if df is None or df.shape[1] < 3:  # a dendrogram of two leaves carries no structure
+      return
+    try:
+      from scipy.cluster.hierarchy import dendrogram, linkage
+      from scipy.spatial.distance import squareform
+    except Exception:
+      return
+    cols = _descriptor_order(rf, df.columns)
+    labels = [c.split("-")[-1] for c in cols]
+    corr = df[cols].corr(method="spearman").values
+    dist = 1.0 - corr
+    np.fill_diagonal(dist, 0.0)
+    dist = (dist + dist.T) / 2.0  # enforce exact symmetry for squareform
+    z = linkage(squareform(dist, checks=False), method="average")
+    dendrogram(
+      z,
+      labels=labels,
+      orientation="left",
+      ax=self.ax,
+      color_threshold=0,
+      above_threshold_color=_color("inactive"),
+    )
+    for lbl in self.ax.get_yticklabels():
+      lbl.set_fontsize(7)
+    self.ax.tick_params(axis="x", labelsize=6)
+    self.ax.set_xlabel("1 − Spearman")
+    self.ax.set_title("Descriptor rank-agreement clustering")
+    self.is_available = True
+
+
+class PooledVsDescriptorScatterPlot(BasePlot):
+  """Small-multiples: each descriptor's out-of-fold score vs the pooled model's OOF score, one panel
+  per descriptor with the Spearman ρ. Shows which descriptors the pool tracks most closely (ρ→1,
+  points hugging the diagonal) and which pull against it. Classification only, fit-only."""
+
+  def __init__(self, ax, path):
+    BasePlot.__init__(self, ax=ax, path=path, cells=(3, 4))
+    self.name = "descriptor-pooled-scatter"
+    self.is_available = False
+    if not self.has_clf_data():
+      return
+    rf = ResultsFetcher(path=path)
+    tasks = rf.get_clf_tasks()
+    if not tasks:
+      return
+    df = rf._read_individual_estimator_results(tasks[0])
+    pooled = rf._read_pooled_results()
+    if df is None or df.shape[1] < 1 or pooled is None or tasks[0] not in pooled.columns:
+      return
+    p = pooled[tasks[0]].to_numpy(dtype=float)
+    if len(p) != len(df):  # pooled and per-descriptor frames must be row-aligned (compound order)
+      return
+    cols = _descriptor_order(rf, df.columns)
+    labels = [c.split("-")[-1] for c in cols]
+    import math
+
+    # Replace the single default axes with a grid of per-descriptor panels on the same figure.
+    fig = self.ax.figure
+    self.ax.remove()
+    ncol = min(3, len(cols))
+    nrow = math.ceil(len(cols) / ncol)
+    gs = fig.add_gridspec(nrow, ncol, hspace=0.6, wspace=0.4)
+    color = _color("inactive")
+    p_series = pd.Series(p)
+    for idx, (c, lbl) in enumerate(zip(cols, labels)):
+      ax = fig.add_subplot(gs[idx // ncol, idx % ncol])
+      x = df[c].to_numpy(dtype=float)
+      ax.scatter(x, p, s=3, alpha=0.35, color=color, edgecolors="none", rasterized=True)
+      ax.plot([0, 1], [0, 1], color="#bbbbbb", lw=0.6, ls="--")
+      rho = pd.Series(x).corr(p_series, method="spearman")
+      ax.set_title(f"{lbl}  ρ={rho:.2f}" if rho == rho else lbl, fontsize=7)
+      ax.set_xlim(0, 1)
+      ax.set_ylim(0, 1)
+      ax.set_xticks([0, 0.5, 1])
+      ax.set_yticks([0, 0.5, 1])
+      ax.tick_params(labelsize=6)
+      if idx % ncol == 0:
+        ax.set_ylabel("Pooled", fontsize=7)
+      if idx // ncol == nrow - 1:
+        ax.set_xlabel("Descriptor", fontsize=7)
     self.is_available = True
 
 
