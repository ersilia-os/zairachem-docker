+class _DescriptorTopOverlapPlot(BasePlot):
+  """Pairwise overlap of each descriptor's top-fraction *shortlist* of molecules (by OOF score).
+
+  Each descriptor nominates its top ``⌈fraction·N⌉`` molecules; the cell is the **overlap
+  coefficient** ``|A∩B| / min(|A|,|B|)`` — with equal shortlist sizes this is simply the fraction of
+  the shortlist two descriptors agree on. It answers a sharper question than the overall Spearman
+  correlation: do the descriptors surface the *same hits* at the actionable end, even when their
+  full-ranking correlation is high? Classification only; subclasses set ``fraction``/``stem``."""
+
+  fraction = None
+  stem = None
+
+  def __init__(self, ax, path):
+    BasePlot.__init__(self, ax=ax, path=path, cells=(2, 2))
+    self.name = self.stem
+    self.is_available = False
+    if not self.has_clf_data():
+      return
+    rf = ResultsFetcher(path=path)
+    tasks = rf.get_clf_tasks()
+    if not tasks:
+      return
+    df = rf._read_individual_estimator_results(tasks[0])
+    if df is None or df.shape[1] < 2:
+      return
+    n = len(df)
+    k = int(np.ceil(self.fraction * n))
+    if (
+      k < 2 or k >= n
+    ):  # too few (or all) compounds — the top fraction isn't a meaningful shortlist
+      return
+    cols = _descriptor_order(rf, df.columns)
     labels = [c.split("-")[-1] for c in cols]
