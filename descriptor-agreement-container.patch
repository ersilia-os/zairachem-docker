+def _descriptor_order(rf, columns):
+  """Descriptor result columns ordered best-first by inner-CV AUROC (falls back to input order for
+  any descriptor without CV stats), for a consistent reading across the agreement figures."""
+  ranked = [s["descriptor"] for s in rf.get_cv_stats()]
+  return sorted(
+    columns,
+    key=lambda c: ranked.index(c.split("-")[-1]) if c.split("-")[-1] in ranked else 999,
+  )
+
+
+def _agreement_heatmap(ax, m, labels, title, vmin):
+  """Draw a square descriptor-agreement heatmap (white→turquoise), annotated per cell.
+
+  ``m`` is a symmetric matrix in ``[0, 1]`` with a unit diagonal (a correlation or an overlap
+  fraction); ``vmin`` sets the low end of the colour ramp so the off-diagonal spread stays visible.
+  Shared by the correlation and top-shortlist-overlap plots so they read identically."""
+  from matplotlib.colors import LinearSegmentedColormap
+
+  cmap = LinearSegmentedColormap.from_list("stylia_seq", ["#ffffff", _color("inactive")])
+  ax.imshow(m, cmap=cmap, vmin=vmin, vmax=1.0)
+  ax.set_xticks(range(len(labels)))
+  ax.set_yticks(range(len(labels)))
+  ax.set_xticklabels(labels, fontsize=6, rotation=30, ha="right")
+  ax.set_yticklabels(labels, fontsize=6)
+  for i in range(len(labels)):
+    for j in range(len(labels)):
+      ax.text(
+        j,
+        i,
+        f"{m[i, j]:.2f}",
+        va="center",
+        ha="center",
+        fontsize=6,
+        color="white" if m[i, j] > 0.85 else "black",
+      )
+  ax.grid(False)
+  ax.set_title(title)
+
