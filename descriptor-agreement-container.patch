+    d = len(cols)
+    m = np.eye(d)
+    for i in range(d):
+      for j in range(i + 1, d):
+        ov = len(tops[i] & tops[j]) / min(len(tops[i]), len(tops[j]))
+        m[i, j] = m[j, i] = ov
+    off = m[~np.eye(d, dtype=bool)]
+    vmin = max(0.0, float(np.nanmin(off)) - 0.02) if off.size else 0.0
+    pct = f"{self.fraction * 100:g}"
+    _agreement_heatmap(self.ax, m, labels, f"Top-{pct}% shortlist overlap (n={k})", vmin)
